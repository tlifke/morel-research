% morel.sty — Morel brand styling for LaTeX one-pagers
%
% Source of truth for the brand palette and typography:
%   morel-primordia/projects/morel-life/brand-guide/BRAND-GUIDE.md
%
% Usage:
%   \documentclass[10pt]{article}
%   \usepackage{morel}
%   \newcommand{\paperRepoShort}{tlifke/morel-research}  % shown in footer
%   \begin{document}
%   \moreltitle{Title}{Authors}{2026-05-12}{\href{...}{tlifke/morel-research}}{short/study/ref}
%   \section*{Research question} ...
%   \section*{Context} ...
%   \section*{Methods} ...
%   ...
%   \end{document}
%
% Compile with: latexmk -xelatex one-pager.tex   (xelatex is required for fontspec).

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{morel}[2026/05/12 v1.0 Morel brand styling for one-pagers]

\RequirePackage{xcolor}
\RequirePackage{fontspec}
\RequirePackage{titlesec}
\RequirePackage{enumitem}
\RequirePackage{fancyhdr}
\RequirePackage{caption}
\RequirePackage{geometry}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{microtype}
\RequirePackage{parskip}
\RequirePackage{graphicx}

\geometry{a4paper,margin=0.7in}

% ----- Brand palette --------------------------------------------------------
\definecolor{morelprimary}{HTML}{C1694F}     % Terracotta
\definecolor{morelaccent}{HTML}{2D5016}      % Forest Green
\definecolor{morelslate}{HTML}{3D6478}       % Slate Blue
\definecolor{morelparchment}{HTML}{F5E6D3}   % Parchment Cream
\definecolor{moreldark}{HTML}{3B2F2F}        % Dark Earth (body text)
\definecolor{morelpage}{HTML}{FAFAF8}        % Off-White (page bg)
\definecolor{morelborder}{HTML}{E8D5BF}      % Cream Dark (dividers)
\definecolor{morelmuted}{HTML}{6B5E5E}       % Muted text

\AtBeginDocument{\color{moreldark}}

% ----- Typography ----------------------------------------------------------
% Brand fonts: Inter / DM Sans body, DM Serif Display for the title.
% Fall back gracefully on plain TeX installs.
\IfFontExistsTF{Inter}{%
  \setmainfont{Inter}[
    UprightFont = * Regular,
    BoldFont    = * SemiBold,
    ItalicFont  = * Italic,
    Scale       = 1.0,
  ]%
}{%
  \IfFontExistsTF{DM Sans}{%
    \setmainfont{DM Sans}%
  }{%
    \setmainfont{Helvetica Neue}%
  }%
}

\IfFontExistsTF{DM Serif Display}{%
  \newfontfamily\morelserif{DM Serif Display}%
}{%
  \newfontfamily\morelserif{Georgia}%
}

% ----- Section headings -----------------------------------------------------
% Forest-green, bold, slightly above body size. Tight vertical rhythm so
% multiple sections + a figure + takeaways fit on one A4 page.
\titlespacing*{\section}{0pt}{0.9em}{0.3em}
\titleformat{\section}{\normalfont\bfseries\large\color{morelaccent}}{}{0pt}{}

% ----- Lists ----------------------------------------------------------------
\setlist[itemize]{leftmargin=1.2em,topsep=0.2em,itemsep=0.15em,parsep=0pt}

% ----- Figure captions ------------------------------------------------------
% Small font, bold/colored "Figure N." label, period separator, tight skip.
\captionsetup{
  font=small,
  labelfont={bf,color=morelaccent},
  labelsep=period,
  skip=4pt,
  justification=raggedright,
  singlelinecheck=false,
}

% ----- Page furniture -------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyfoot[L]{\footnotesize\color{morelmuted}\textbf{\color{morelprimary}morel}\,\textbullet\,research}
\fancyfoot[R]{\footnotesize\color{morelmuted}\paperRepoShort}

% ----- Title block ----------------------------------------------------------
% \moreltitle{TITLE}{AUTHORS}{DATE}{REPO-LINK}{STUDY-REF-SHORT}
%
% Renders:
%   - title in serif display face, dark earth
%   - one metadata line in muted text: authors • date • repo • study-ref
%   - terracotta rule + thin cream rule below
%
% Keep STUDY-REF-SHORT under ~50 chars or it will crowd the line.
\newcommand{\moreltitle}[5]{%
  \noindent
  \begin{minipage}[t]{\linewidth}
    \vspace{0pt}
    {\morelserif\Huge\color{moreldark}#1\par}
    \vspace{0.35em}
    {\small\color{morelmuted}#2\ \textbullet\ #3\ \textbullet\ #4\ \textbullet\ \texttt{\small #5}\par}
  \end{minipage}
  \vspace{0.4em}
  {\color{morelprimary}\hrule height 1.2pt}
  \vspace{0.08em}
  {\color{morelborder}\hrule height 0.4pt}
  \vspace{0.7em}
}

\endinput
