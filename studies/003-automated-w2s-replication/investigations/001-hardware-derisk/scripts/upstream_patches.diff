diff --git a/w2s_research/core/train_eval.py b/w2s_research/core/train_eval.py
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/w2s_research/core/train_eval.py
@@ -0,0 +1,63 @@
+"""
+Out-of-process evaluation entrypoint.
+
+Invoked via `python -m w2s_research.core.train_eval --inputs-dir <dir> --output-json <path>`.
+The parent process (train.py) writes serialized eval inputs into <inputs-dir>, exits its
+own training pipeline, and launches this subprocess. Running vLLM in a fresh Python
+process guarantees a clean CUDA context (the parent's training-time context is not
+released by `del model + gc.collect + empty_cache` alone — that's a process-lifetime
+property on a 12 GB GPU where the strong-model weights leave no headroom otherwise).
+"""
+import argparse
+import json
+import pickle
+import sys
+from pathlib import Path
+
+from .eval import evaluate_model, generate_predictions
+
+
+def main():
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--inputs-dir", required=True)
+    parser.add_argument("--output-json", required=True)
+    args = parser.parse_args()
+
+    inputs_dir = Path(args.inputs_dir)
+    with open(inputs_dir / "inputs.pkl", "rb") as f:
+        inputs = pickle.load(f)
+
+    aar_mode = inputs["aar_mode"]
+    common_kwargs = dict(
+        test_dataset=inputs["test_formatted"],
+        label_token_ids=inputs["label_token_ids"],
+        tokenizer=inputs["tokenizer"],
+        model_name=inputs["model_name"],
+        lora_checkpoint=inputs["lora_checkpoint"],
+        max_model_len=inputs["max_model_len"],
+        gpu_memory_utilization=inputs.get("gpu_memory_utilization", 0.8),
+    )
+
+    if aar_mode:
+        pred_result = generate_predictions(**common_kwargs)
+        output = {
+            "aar_mode": True,
+            "predictions": pred_result["predictions"],
+            "num_samples": pred_result["num_samples"],
+            "pred_distribution": pred_result["pred_distribution"],
+        }
+    else:
+        final_eval = evaluate_model(
+            original_dataset=inputs["original_dataset"],
+            **common_kwargs,
+        )
+        output = {"aar_mode": False, "final_eval": final_eval}
+
+    with open(args.output_json, "w") as f:
+        json.dump(output, f)
+
+    sys.exit(0)
+
+
+if __name__ == "__main__":
+    main()
