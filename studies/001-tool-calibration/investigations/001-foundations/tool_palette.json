{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool_palette.json",
  "title": "Tool palette (frozen)",
  "description": "Six-tool palette for the matched-pair tool-calibration study. Mirrors tool_palette.py. Frozen 2026-05-11; Decision 8 (2026-05-11) split knowledge_lookup into general_knowledge_lookup + user_knowledge_lookup. Further changes require a new investigation.",
  "version": "1.1.0",
  "frozen_on": "2026-05-11",
  "tools": [
    {
      "name": "calculator",
      "summary": "Evaluate an arithmetic expression and return the exact result.",
      "parameters": {
        "type": "object",
        "properties": {
          "expression": {
            "type": "string",
            "description": "Arithmetic expression, e.g. '47*83' or 'sqrt(2)'."
          }
        },
        "required": ["expression"],
        "additionalProperties": false
      },
      "returns": {"type": "string"},
      "examples": [
        {"expression": "47*83"},
        {"expression": "sqrt(2)"}
      ],
      "cognitive_moment": "compute-I-can't-do"
    },
    {
      "name": "python_execute",
      "summary": "Run a snippet of Python and return its stdout. Use when the calculator is insufficient.",
      "parameters": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Python source code; stdout is returned to the caller."
          }
        },
        "required": ["code"],
        "additionalProperties": false
      },
      "returns": {"type": "string"},
      "examples": [
        {"code": "print(sum(range(1, 101)))"},
        {"code": "import math; print(math.factorial(20))"}
      ],
      "cognitive_moment": "transform-deterministically"
    },
    {
      "name": "datetime_now",
      "summary": "Return the current date and time as an ISO-8601 string. Takes no arguments.",
      "parameters": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "returns": {"type": "string"},
      "examples": [{}],
      "cognitive_moment": "look-up-I-don't-know (temporal)"
    },
    {
      "name": "unit_convert",
      "summary": "Convert a numeric quantity between two units.",
      "parameters": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "description": "Numeric quantity to convert."
          },
          "from_unit": {
            "type": "string",
            "description": "Source unit, case-insensitive (e.g. 'kg', 'meters', 'celsius')."
          },
          "to_unit": {
            "type": "string",
            "description": "Target unit, case-insensitive."
          }
        },
        "required": ["value", "from_unit", "to_unit"],
        "additionalProperties": false
      },
      "returns": {"type": "string"},
      "examples": [
        {"value": 180, "from_unit": "cm", "to_unit": "in"},
        {"value": 72, "from_unit": "fahrenheit", "to_unit": "celsius"}
      ],
      "cognitive_moment": "transform-deterministically"
    },
    {
      "name": "general_knowledge_lookup",
      "summary": "Search an external KB of time-anchored world facts (sports, markets, AI/tech news). Mimics web search: ranked list of records out; empty list on miss.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Free-form natural-language query."
          }
        },
        "required": ["query"],
        "additionalProperties": false
      },
      "returns": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "string"},
                "date": {"type": "string", "format": "date"},
                "domain": {"type": "string"},
                "snippet": {"type": "string"}
              },
              "required": ["id", "date", "domain", "snippet"]
            }
          }
        },
        "required": ["results"]
      },
      "examples": [
        {"query": "Arsenal Manchester City April 2026"},
        {"query": "S&P 500 market cap May 6 2026"}
      ],
      "cognitive_moment": "look-up-I-don't-know (world, post-cutoff)"
    },
    {
      "name": "user_knowledge_lookup",
      "summary": "Search the user's private profile (identity, family, calendar, preferences). Same shape as general_knowledge_lookup.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Free-form natural-language query over the user's private context."
          }
        },
        "required": ["query"],
        "additionalProperties": false
      },
      "returns": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {"type": "string"},
                "snippet": {"type": "string"}
              },
              "required": ["field", "snippet"]
            }
          }
        },
        "required": ["results"]
      },
      "examples": [
        {"query": "wedding anniversary"},
        {"query": "daughter's school"}
      ],
      "cognitive_moment": "look-up-I-can't-know (private)"
    }
  ]
}
