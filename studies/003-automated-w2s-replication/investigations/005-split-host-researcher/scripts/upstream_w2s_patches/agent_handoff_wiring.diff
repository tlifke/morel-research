+    def _maybe_handoff(self, agent_last_messages):
+        """inv 005: extract iteration state and override the next prompt with
+        a bootstrap message referencing the prior session's handoff artifact."""
+        if os.environ.get("HANDOFF_ENABLE") != "1":
+            return
+        if not _HAND_AVAILABLE or agent_last_messages is None:
+            print("[Handoff] disabled — module unavailable or messages missing")
+            return
+        try:
+            server_acks = self._extract_evaluate_predictions_ack(agent_last_messages)
+            state = _hand_extract(agent_last_messages, server_acks=server_acks)
+            handoff_dir = self.workspace / ".agent_handoff"
+            path = _hand_write(state, handoff_dir, self.session_count)
+            print(f"[Handoff] wrote {path.name}  ran_to_completion={state['result']['ran_to_completion']}")
+            self._prompt = _hand_bootstrap(path, self.session_count, prior_state=state)
+            print(f"[Handoff] next prompt set to bootstrap (iteration {self.session_count + 1})")
+        except Exception as e:
+            print(f"[Handoff] WARNING: handoff failed: {e}")
+
+    @staticmethod
+    def _extract_evaluate_predictions_ack(messages):
+        """Parse orchestrator JSON ack out of evaluate_predictions tool_result text.
+        Returns dict or None if no submission happened or ack not parseable."""
+        import json as _json
+        pending = None
+        for msg in messages:
+            content = getattr(msg, "content", None)
+            if content is None:
+                continue
+            for block in content:
+                cls = type(block).__name__
+                if cls == "ToolUseBlock" and getattr(block, "name", "").endswith("evaluate_predictions"):
+                    pending = getattr(block, "id", None)
+                elif cls == "ToolResultBlock" and getattr(block, "tool_use_id", None) == pending:
+                    txt = getattr(block, "content", "")
+                    if isinstance(txt, list):
+                        txt = "".join(
+                            (item.get("text", "") if isinstance(item, dict) else getattr(item, "text", ""))
+                            for item in txt
+                        )
+                    if isinstance(txt, str):
+                        for piece in (txt, txt.strip()):
+                            try:
+                                d = _json.loads(piece)
+                                if isinstance(d, dict):
+                                    return d
+                            except Exception:
+                                pass
+                    pending = None
+        return None
+
